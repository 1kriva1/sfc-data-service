{
  "ConnectionStrings": {
    "Database": "Server=sfc-mssql,1433;Database=Data;User Id=sfc;Password=Test1234!;TrustServerCertificate=True;",
    "Hangfire": "Server=sfc-mssql,1433;Database=Hangfire;User Id=sfc;Password=Test1234!;TrustServerCertificate=True;",
    "RabbitMq": "rabbitmq://sfc-rabbitmq:5672",
    "Redis": "sfc-redis:6379"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Information"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://+:7465",
        "Protocols": "Http1"
      },
      "Https&Grpc": {
        "Url": "https://+:7466",
        "Protocols": "Http1AndHttp2"
      }
    },
    "Certificates": {
      "Default": {
        "Path": "/https/sfc-data.pfx",
        "Password": "Test1234!"
      }
    }
  },
  "Identity": {
    "Authority": "https://sfc-identity",
    "Audience": "sfc.data",
    "RequireClaims": {
      "scope": [ "sfc.data.full" ]
    }
  },
  "Redis": {
    "User": "sfc",
    "Password": "Test1234!",
    "InstanceName": "SFC.Data"
  },
  "RabbitMq": {
    "Username": "sfc",
    "Password": "Test1234!",
    "Name": "SFC.Data",
    "Retry": {
      "Limit": 5,
      "Intervals": [ 1, 5, 10 ]
    },
    "Exchanges": {
      "Data": {
        "Key": "data",
        "Value": {
          "Data": {
            "Initialized": {
              "Name": "sfc.data.initialized",
              "Type": "fanout"
            }
          }
        }
      },
      "Player": {
        "Key": "player",
        "Value": {
          "Data": {
            "Initialize": {
              "Name": "sfc.player.data.initialize"
            },
            "RequireInitialize": {
              "Name": "sfc.player.data.initialize.require"
            }
          }
        }
      },
      "Team": {
        "Key": "team",
        "Value": {
          "Data": {
            "Initialize": {
              "Name": "sfc.team.data.initialize"
            },
            "RequireInitialize": {
              "Name": "sfc.team.data.initialize.require"
            }
          }
        }
      },
      "Invite": {
        "Key": "invite",
        "Value": {
          "Data": {
            "Initialize": {
              "Name": "sfc.invite.data.initialize"
            },
            "RequireInitialize": {
              "Name": "sfc.invite.data.initialize.require"
            }
          }
        }
      },
      "Request": {
        "Key": "request",
        "Value": {
          "Data": {
            "Initialize": {
              "Name": "sfc.request.data.initialize"
            },
            "RequireInitialize": {
              "Name": "sfc.request.data.initialize.require"
            }
          }
        }
      },
      "Scheme": {
        "Key": "request",
        "Value": {
          "Data": {
            "Initialize": {
              "Name": "sfc.scheme.data.initialize"
            },
            "RequireInitialize": {
              "Name": "sfc.scheme.data.initialize.require"
            }
          }
        }
      }
    }
  },
  "Hangfire": {
    "SchemaNamePrefix": "Data",
    "Retry": {
      "Attempts": 5,
      "DelaysInSeconds": [ 1, 5, 10 ]
    },
    "Dashboard": {
      "Title": "SFC.Data",
      "Login": "sfc",
      "Password": "Test1234!"
    }
  },
  "Cache": {
    "Enabled": true,
    "InstanceName": "SFC.Data",
    "AbsoluteExpirationInMinutes": 15,
    "SlidingExpirationInMinutes": 45,
    "Refresh": {
      "Cron": "*/15 * * * *"
    }
  },
  "Grpc": {
    "MaxReceiveMessageSizeInMb": 2,
    "MaxSendMessageSizeInMb": 4
  }
}
