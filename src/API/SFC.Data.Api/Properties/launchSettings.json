{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "SFC.Data": {
      "commandName": "Project",
      "launchBrowser": true,
      "launchUrl": "swagger",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://+:7466;http://+:7465",
        "ASPNETCORE_HTTPS_PORT": "7466",
        "ConnectionStrings__Database": "Server=127.0.0.1,1433;Database=Data;User Id=sfc;Password=Test1234!;TrustServerCertificate=True;",
        "ConnectionStrings__Hangfire": "Server=127.0.0.1,1433;Database=Hangfire;User Id=sfc;Password=Test1234!;TrustServerCertificate=True;",
        "ConnectionStrings__RabbitMq": "rabbitmq://localhost:5672",
        "ConnectionStrings__Redis": "localhost:6379"
      },
      "dotnetRunMessages": true,
      "applicationUrl": "https://localhost:7466;http://localhost:7465",
      "httpPort": 7465,
      "useSSL": true,
      "sslPort": 7466,
      "nativeDebugging": true
    },
    "Docker": {
      "commandName": "Docker",
      "launchBrowser": true,
      "launchUrl": "{Scheme}://{ServiceHost}:{ServicePort}/swagger",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://+:7466;http://+:7465",
        "ASPNETCORE_HTTPS_PORT": "7466"
      },
      "mycontainer": "sfc-data",
      "DockerfileRunArguments": "--network sfc-network",
      "httpPort": 7465,
      "useSSL": true,
      "sslPort": 7466,
      "containerName": "sfc-data"
    }
  }
}